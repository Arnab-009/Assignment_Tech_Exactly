# =============================================================================
# Document Summarizer — Environment Variables
#
# This is the single source of truth for all environment configuration.
#
# Docker usage:
#   cp .env.example .env        # then edit .env with your real values
#   docker compose up --build
#
# Local development:
#   cp .env.example backend/.env   # backend reads from its own working dir
#   # Edit backend/.env — set GOOGLE_REDIRECT_URI and POST_LOGIN_REDIRECT
#   # to http://localhost:5173/... for the Vite dev proxy.
# =============================================================================

# --- Google OAuth2 (from Google Cloud Console > Credentials) -----------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an Authorized redirect URI in the OAuth client.
#   Docker (default):  http://localhost:8080/api/auth/callback
#   Local dev (Vite):  http://localhost:5173/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Where the user is sent after a successful login (your frontend origin).
#   Docker:    http://localhost:8080
#   Local dev: http://localhost:5173
POST_LOGIN_REDIRECT=http://localhost:8080

# --- Gemini (from https://aistudio.google.com/apikey) ------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Session security --------------------------------------------------------
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
SESSION_HTTPS_ONLY=false

# --- App behaviour -----------------------------------------------------------
# A Drive folder ID to pre-fill in the UI for quick testing (optional).
DEFAULT_FOLDER_ID=

CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# --- Limits / tuning ---------------------------------------------------------
MAX_FILES_PER_RUN=20
MAX_FILE_SIZE_MB=10
MAX_TEXT_CHARS=50000
LLM_CONCURRENCY=5
SUMMARIZE_COOLDOWN_SECONDS=30
LOG_LEVEL=INFO
